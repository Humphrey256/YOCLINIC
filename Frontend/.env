# .env file for frontend

# Define the base URL for API requests (update with your API URL)
VITE_API_BASE_URL=https://yoclinic-12.onrender.com
# Set the port for Vite development server (optional)
VITE_PORT=3000
VITE_API_BASE_URL =https://yoclinic-11.onrender.com

# Enable/Disable React Strict Mode (set to false for production)
VITE_REACT_STRICT_MODE=true

# Set the environment (development or production)
VITE_ENV=development

# Other environment variables can go here, for example:
VITE_APP_NAME=YOCLINIC
VITE_APP_VERSION=1.0.0
